# URL du site (sans trailing slash)
NEXT_PUBLIC_SITE_URL=https://leconseillerfiscal.com

# ── Tracking de conversion (chargé UNIQUEMENT après consentement cookies) ───
# GA4 : Google Analytics → Admin → Flux de données → ID de mesure (format G-XXXXXXX)
NEXT_PUBLIC_GA_ID=
# Meta Pixel : Gestionnaire d'événements Meta → ID du pixel (numérique)
NEXT_PUBLIC_META_PIXEL_ID=

# ── Supabase — persistance des messages/leads + dashboard /admin ───────────
# Projet partagé "guide-taechir" (tables préfixées lcf_). URL + clé publishable
# sont PUBLIQUES (clé insert-only via RLS) : valeurs par défaut dans src/lib/supabase.ts.
# À surcharger seulement si vous changez de projet.
NEXT_PUBLIC_SUPABASE_URL=https://yjxuutdnhsvrbbgcqltw.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_x4ehI4AgVADT4U190djnGg_eXRCPd9c

# ── Resend — emails transactionnels (notifications lead & contact) ──────────
# https://resend.com/api-keys
RESEND_API_KEY=

# Email de réception des leads et messages de contact
CONTACT_EMAIL=contact@leconseillerfiscal.com

# Adresse expéditrice des e-mails sortants (Brevo + Resend). Défaut : contact@.
# Le domaine doit être authentifié chez Brevo et vérifié chez Resend.
MAIL_FROM_EMAIL=contact@leconseillerfiscal.com

# ── Brevo — newsletter & séquences de nurturing lead ───────────────────────
# https://app.brevo.com/settings/keys/api
BREVO_API_KEY=

# ID de la liste Brevo pour les abonnés newsletter (Contacts → Listes)
BREVO_NEWSLETTER_LIST_ID=

# ID de la liste Brevo pour les leads bilan fiscal (Contacts → Listes)
BREVO_LEADS_LIST_ID=

# ── Attributs personnalisés à créer dans Brevo ─────────────────────────────
# Contacts → Paramètres → Attributs de contact → Ajouter un attribut
# Noms attendus : PAYS_CIBLE, SITUATION, REVENUS, SOURCE (type Texte)
